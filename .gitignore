.env
.env.local
.env.*.local

# ── Testing & coverage ──────────────────────────────────────────────────────
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.tox/

# ── IDEs ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Node (if any frontend tooling is added later) ───────────────────────────
node_modules/
npm-debug.log*

# ── Byte-compiled / optimised / DLL files ───────────────────────────────────
**/*.pyc
