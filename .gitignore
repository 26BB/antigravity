# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Django ──────────────────────────────────────────────────────────────────
*.log
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/

# ── Environment & secrets  ──────────────────────────────────────────────────
