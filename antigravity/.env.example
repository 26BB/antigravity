# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in real values
# NEVER commit .env — it's in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Django secret key — generate one at: https://djecrety.ir/
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars

# Set to False in production ALWAYS
DEBUG=True

# Comma-separated list of allowed hosts — e.g. yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection URL (used in production)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://user:password@localhost:5432/antigravity_db

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to make cross-site requests
CORS_ALLOWED_ORIGINS=http://localhost:3000
